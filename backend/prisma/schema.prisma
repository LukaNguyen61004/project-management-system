// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  member
}

enum IssueType {
  task
  bug
  story
  subtask
}

enum IssueStatus {
  todo
  in_progress
  in_review
  done
}

enum IssuePriority {
  low
  medium
  high
  critical
}

enum SprintStatus {
  planned
  active
  completed
}

enum NotificationType {
  issue_assigned
  issue_updated
  sprint_created
  project_invitation
  comment_added
  stale_issue_warning
}

enum ActivityActionType {
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_DELETED
  MEMBER_INVITED
  INVITATION_ACCEPTED
  MEMBER_REMOVED
  MEMBER_LEFT
  ISSUE_CREATED
  ISSUE_UPDATED
  STATUS_CHANGED
  ISSUE_ASSIGNED
  PRIORITY_CHANGED
  ISSUE_MOVED_TO_SPRINT
  ISSUE_DELETED
  SPRINT_CREATED
  SPRINT_UPDATED
  SPRINT_STATUS_CHANGED
  COMMENT_ADDED
  COMMENT_UPDATED
  COMMENT_DELETED
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

model User {
  user_id    Int    @id @default(autoincrement())
  user_email String @unique

  user_password_hash String?
  refresh_token      String?

  user_name       String?
  user_avatar_url String?

  provider AuthProvider @default(LOCAL)

  user_created_at DateTime @default(now())
  user_updated_at DateTime @default(now()) @updatedAt

  owned_projects      Project[]
  project_memberships ProjectMember[]

  reported_issues Issue[] @relation("Reporter")
  assigned_issues Issue[] @relation("Assignee")

  created_epics   Epic[]
  created_sprints Sprint[]

  comments Comment[]

  notifications      Notification[] @relation("NotificationReceiver")
  sent_notifications Notification[] @relation("NotificationSender")

  invitations_sent ProjectInvitation[]

  activity_logs ActivityLog[]
}

model Project {
  project_id          Int      @id @default(autoincrement())
  project_name        String
  project_key         String   @unique
  project_description String?
  owner_id            Int
  project_created_at  DateTime @default(now())

  owner User @relation(fields: [owner_id], references: [user_id])

  members       ProjectMember[]
  epics         Epic[]
  sprints       Sprint[]
  issues        Issue[]
  notifications Notification[]
  invitations   ProjectInvitation[]
  activity_logs ActivityLog[]

  @@index([project_key])
  @@index([owner_id])
}

model ProjectMember {
  pm_id Int @id @default(autoincrement())

  project_id Int
  user_id    Int

  role UserRole @default(member)

  joined_at DateTime @default(now())

  project Project @relation(fields: [project_id], references: [project_id])
  user    User    @relation(fields: [user_id], references: [user_id])

  @@unique([project_id, user_id])
  @@index([project_id])
  @@index([user_id])
}

model Epic {
  epic_id Int @id @default(autoincrement())

  project_id Int

  epic_name String

  epic_description String?

  epic_color String @default("#8B5CF6")

  created_by Int

  epic_created_at DateTime @default(now())
  epic_updated_at DateTime @updatedAt

  project Project @relation(fields: [project_id], references: [project_id])

  creator User @relation(fields: [created_by], references: [user_id])

  issues Issue[]

  @@index([project_id])
}

model Sprint {
  sprint_id Int @id @default(autoincrement())

  project_id Int

  sprint_name String

  description String?

  sprint_status SprintStatus @default(planned)

  start_date DateTime?

  end_date DateTime?

  created_by Int

  sprint_created_at DateTime @default(now())
  sprint_updated_at DateTime @updatedAt

  project Project @relation(fields: [project_id], references: [project_id])

  creator User @relation(fields: [created_by], references: [user_id])

  issues Issue[]

  notifications Notification[]

  activity_logs ActivityLog[]

  @@unique([project_id, sprint_name])
  @@index([project_id])
  @@index([sprint_status])
}

model Issue {
  issue_id Int @id @default(autoincrement())

  project_id Int

  sprint_id Int?

  epic_id Int?

  issue_key String @unique

  issue_name String

  issue_description String?

  issue_type IssueType @default(task)

  issue_status IssueStatus @default(todo)

  issue_priority IssuePriority @default(low)

  reporter_id Int

  assignee_id Int?

  last_activity_at DateTime @default(now())

  warning_count Int @default(0)

  review_reject_count Int @default(0)

  issue_created_at DateTime @default(now())
  issue_updated_at DateTime @updatedAt

  project Project @relation(fields: [project_id], references: [project_id])

  sprint Sprint? @relation(fields: [sprint_id], references: [sprint_id])

  epic Epic? @relation(fields: [epic_id], references: [epic_id])

  reporter User @relation("Reporter", fields: [reporter_id], references: [user_id])

  assignee User? @relation("Assignee", fields: [assignee_id], references: [user_id])

  comments Comment[]

  notifications Notification[]

  activity_logs ActivityLog[]

  @@index([issue_key])
  @@index([project_id])
  @@index([sprint_id])
  @@index([epic_id])
  @@index([reporter_id])
  @@index([assignee_id])
  @@index([issue_status])
  @@index([issue_priority])
  @@index([last_activity_at])
}

model Comment {
  comment_id Int @id @default(autoincrement())

  issue_id Int

  user_id Int

  content String

  created_at DateTime @default(now())

  updated_at DateTime @updatedAt

  issue Issue @relation(fields: [issue_id], references: [issue_id])

  user User @relation(fields: [user_id], references: [user_id])

  @@index([issue_id])
  @@index([user_id])
}

model Notification {
  notifi_id Int @id @default(autoincrement())

  user_id Int

  sender_id Int?

  notifi_type NotificationType

  notifi_title String

  notifi_content String

  is_read Boolean @default(false)

  related_issue_id Int?

  related_project_id Int?

  related_sprint_id Int?

  notifi_created_at DateTime @default(now())

  receiver User @relation("NotificationReceiver", fields: [user_id], references: [user_id])

  sender User? @relation("NotificationSender", fields: [sender_id], references: [user_id])

  related_issue Issue? @relation(fields: [related_issue_id], references: [issue_id])

  related_project Project? @relation(fields: [related_project_id], references: [project_id])

  related_sprint Sprint? @relation(fields: [related_sprint_id], references: [sprint_id])

  @@index([user_id])
  @@index([notifi_created_at])
  @@index([user_id, is_read])
}

model ProjectInvitation {
  invitation_id Int @id @default(autoincrement())

  project_id Int

  email String

  token String @unique

  role_member UserRole @default(member)

  invited_by Int

  expires_at DateTime

  accepted_at DateTime?

  created_at DateTime @default(now())

  project Project @relation(fields: [project_id], references: [project_id])

  inviter User @relation(fields: [invited_by], references: [user_id])

  @@index([project_id])
  @@index([email])
  @@index([token])
}

model ActivityLog {
  log_id Int @id @default(autoincrement())

  user_id Int

  project_id Int

  issue_id Int?

  sprint_id Int?

  action_type ActivityActionType

  field_name String?

  old_value String?

  new_value String?

  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [user_id])

  project Project @relation(fields: [project_id], references: [project_id])

  issue Issue? @relation(fields: [issue_id], references: [issue_id])

  sprint Sprint? @relation(fields: [sprint_id], references: [sprint_id])

  @@index([user_id])
  @@index([project_id])
  @@index([issue_id])
  @@index([action_type])
  @@index([created_at])
}
