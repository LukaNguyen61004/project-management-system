# Server
PORT=5000

# PostgreSQL (Neon) — Prisma connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Firebase Admin — paste full service account JSON as one line (Render/production)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Stale issue warning cron
STALE_DAYS=7
STALE_CRON_SCHEDULE=0 9 * * *

# Optional — restrict CORS in production
# FRONTEND_URL=https://your-app.vercel.app
